#!/bin/sh
set -e

# Block direct commits to main
branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
  echo "Error: Direct commits to $branch are not allowed. Use a branch + PR."
  exit 1
fi

# Run lint, fmt, type-check, and tests
echo "Running checks..."
deno task check
