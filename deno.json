{
  "name": "@aai/server",
  "version": "0.1.218",
  "exports": {
    ".": "./main.ts",
    "./testing": "./_test_utils.ts"
  },
  "imports": {
    "@aai/sdk": "npm:@alexkroman1/aai-sdk@^0.8",
    "@aai/sdk/types": "npm:@alexkroman1/aai-sdk@^0.8/types",
    "@aai/sdk/kv": "npm:@alexkroman1/aai-sdk@^0.8/kv",
    "@aai/sdk/internal-types": "npm:@alexkroman1/aai-sdk@^0.8/internal-types",
    "@aai/sdk/protocol": "npm:@alexkroman1/aai-sdk@^0.8/protocol",
    "@aai/sdk/worker-entry": "npm:@alexkroman1/aai-sdk@^0.8/worker-entry",
    "@aai/sdk/runtime": "npm:@alexkroman1/aai-sdk@^0.8/runtime",
    "@aai/sdk/s2s": "npm:@alexkroman1/aai-sdk@^0.8/s2s",
    "@aai/sdk/session": "npm:@alexkroman1/aai-sdk@^0.8/session",
    "@aai/sdk/builtin-tools": "npm:@alexkroman1/aai-sdk@^0.8/builtin-tools",
    "@aai/sdk/direct-executor": "npm:@alexkroman1/aai-sdk@^0.8/direct-executor",
    "@aai/sdk/vector": "npm:@alexkroman1/aai-sdk@^0.8/vector",
    "@aai/sdk/capnweb": "npm:@alexkroman1/aai-sdk@^0.8/capnweb",
    "@aai/sdk/winterc-server": "npm:@alexkroman1/aai-sdk@^0.8/winterc-server",
    "@aai/sdk/worker-shim": "npm:@alexkroman1/aai-sdk@^0.8/worker-shim",
    "@aai/sdk/testing": "npm:@alexkroman1/aai-sdk@^0.8/testing",

    "@std/testing": "jsr:@std/testing@^1.0.17",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fmt": "jsr:@std/fmt@^1.0.9",
    "@std/cli": "jsr:@std/cli@^1.0.28",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/async": "jsr:@std/async@^1.2.0",
    "@std/dotenv": "jsr:@std/dotenv@0.225.6",
    "@std/bytes": "jsr:@std/bytes@^1.0.6",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/http": "jsr:@std/http@^1.0.25",
    "@std/crypto": "jsr:@std/crypto@^1.0.5",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/log": "jsr:@std/log@^0.224.14",
    "@std/net": "jsr:@std/net@^1.0.6",
    "@std/semver": "jsr:@std/semver@^1.0.8",
    "@std/media-types": "jsr:@std/media-types@^1.1.0",
    "@std/text": "jsr:@std/text@^1.0.17",
    "zod": "npm:zod@^4.3.6",
    "json-schema": "npm:@types/json-schema@^7.0.15",
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@^3.1001.0",
    "@upstash/redis": "npm:@upstash/redis@^1.36.1",
    "@upstash/vector": "npm:@upstash/vector@^1",

    "hono": "npm:hono@^4",
    "jose": "npm:jose@^6",
    "@noble/ciphers": "npm:@noble/ciphers@^1",
    "@noble/hashes": "npm:@noble/hashes@^1",
    "ws": "npm:ws@^8",
    "capnweb": "npm:capnweb@^0.6.1",
    "prom-client": "npm:prom-client@^15",
    "@hono/prometheus": "npm:@hono/prometheus@^1"
  },
  "tasks": {
    "serve": "deno run --allow-all --unstable-worker-options main.ts",
    "test": "deno test --allow-net --allow-read --allow-write --allow-env --allow-run --allow-sys --unstable-worker-options .",
    "check": "deno check *.ts && deno lint && deno fmt --check && deno task test && RUST_MIN_STACK=16777216 deno compile --allow-all --unstable-worker-options --output /tmp/aai-check main.ts && rm -f /tmp/aai-check",
    "setup": "git config core.hooksPath .githooks"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "lib": [
      "deno.ns",
      "deno.unstable",
      "deno.window",
      "dom",
      "dom.iterable",
      "esnext"
    ]
  },
  "fmt": {
    "exclude": ["**/node_modules/"]
  },
  "lint": {
    "exclude": ["**/node_modules/"],
    "rules": {
      "tags": ["recommended", "jsr", "workspace"],
      "include": [
        "camelcase",
        "no-sync-fn-in-async-fn",
        "single-var-declarator",
        "verbatim-module-syntax",
        "no-unused-vars"
      ],
      "exclude": [
        "require-await"
      ]
    }
  },
  "publish": {
    "exclude": [
      "*_test.ts"
    ]
  },
  "license": "MIT"
}
